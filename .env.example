# Copiar a .env y completar. En Vercel, cargar estas mismas variables en
# Project Settings → Environment Variables.

# --- Cliente (expuestas al navegador, prefijo VITE_) ---
VITE_PUBLIC_APP_ID=tu_app_id_de_instantdb
# Clave pública VAPID. Debe coincidir con VAPID_PUBLIC_KEY del backend.
# Generar con: npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# --- Backend / Vercel Functions (NO usar prefijo VITE_; son secretos) ---
INSTANT_APP_ID=tu_app_id_de_instantdb
INSTANT_ADMIN_TOKEN=tu_admin_token_de_instantdb
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:tu-email@dominio.com
# Protege el cron: Vercel manda "Authorization: Bearer <CRON_SECRET>".
CRON_SECRET=una_cadena_larga_y_aleatoria
